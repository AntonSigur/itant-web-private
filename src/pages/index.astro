---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import site from '../data/site.json';
import services from '../data/services.json';

const mailto = `mailto:${site.email}?subject=${encodeURIComponent('IT Ant — enquiry')}`;
---
<Base>
  <header class="site-header">
    <div class="container site-header__inner">
      <a class="brand" href="#top" aria-label={`${site.company} — home`}>
        <img src="/brand/itant-logo.svg" alt="" width="38" height="38" />
        <span class="brand__name">IT&nbsp;<span>Ant</span></span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <div class="site-nav__links">
          <a href="#expertise">Expertise</a>
          <a href="#ventures">Products</a>
          <a href="#contact">Contact</a>
        </div>
      </nav>
    </div>
  </header>

  <main id="main">
    <!-- Hero -->
    <section class="hero" id="top">
      <div class="container hero__inner">
        <div class="hero__copy">
          <span class="eyebrow">{site.company} · {site.location}</span>
          <h1>Senior enterprise architecture for complex systems.</h1>
          <p class="hero__sub">{site.subtagline}</p>
          <p class="hero__desc">{site.heroDescription}</p>
          <div class="hero__cta">
            <a class="btn btn--primary" href="#expertise">Areas of expertise</a>
          </div>
          <!-- The "IT Ant ≈ IT consultAnt" wordplay, kept understated. -->
          <p class="hero__pun">IT Ant — your IT <span>consultAnt</span>.</p>
        </div>
        <div class="hero__art">
          <img
            src="/brand/itant-logo.svg"
            alt={`${site.company} logo — a stylised ant`}
            width="380"
            height="285"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>

    <!-- Expertise -->
    <section class="section" id="expertise">
      <div class="container">
        <div class="section__head">
          <span class="eyebrow">Areas of expertise</span>
          <h2>Architecture you can build on</h2>
          <p>
            A focused, senior practice led by {site.principal.name},
            {site.principal.title.toLowerCase()}. Deep, hands-on expertise
            across the work that keeps complex systems coherent — senior,
            direct, and close to delivery.
          </p>
        </div>
        <div class="cards">
          {services.map((s) => (
            <article class="card">
              <span class="card__icon"><Icon name={s.icon} /></span>
              <h3>{s.title}</h3>
              <p>{s.summary}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Products / ventures -->
    <section class="section ventures" id="ventures">
      <div class="container ventures__inner">
        <div>
          <span class="eyebrow">Products &amp; ventures</span>
          <h2>{site.lineage.intro}</h2>
          <p>{site.lineage.body}</p>
          <div class="ventures__links">
            <a class="btn btn--on-ink" href={site.lineage.g9Url} rel="noopener" target="_blank">
              {site.lineage.g9Label} ↗
            </a>
            <a class="btn btn--on-ink" href={site.lineage.certainGuardUrl} rel="noopener" target="_blank">
              {site.lineage.certainGuardLabel} ↗
            </a>
          </div>
        </div>
        <div>
          <article class="venture-card">
            <h3>G9</h3>
            <p>A product house building practical software — the workshop behind the ventures.</p>
            <a href={site.lineage.g9Url} rel="noopener" target="_blank">g9.is ↗</a>
          </article>
          <article class="venture-card">
            <h3>CertainGuard</h3>
            <p>A product for dependable certificate &amp; security lifecycle management.</p>
            <a href={site.lineage.certainGuardUrl} rel="noopener" target="_blank">certainguard.g9.is ↗</a>
          </article>
        </div>
      </div>
    </section>

    <!-- Contact — deliberately quiet & secondary -->
    <section class="section--mist contact-strip" id="contact">
      <div class="container contact-strip__inner">
        <p class="contact-strip__lead">
          For direct enquiries, a quiet note works fine.
        </p>
        <p class="contact-strip__meta">
          <a href={mailto}><Icon name="mail" /> {site.email}</a>
          <span><Icon name="pin" /> {site.location}</span>
        </p>
      </div>
    </section>
  </main>
</Base>
