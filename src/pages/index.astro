---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import site from '../data/site.json';
import services from '../data/services.json';

const mailto = `mailto:${site.email}?subject=${encodeURIComponent('IT Ant — enquiry')}`;
---
<Base>
  <header class="site-header">
    <div class="container site-header__inner">
      <a class="brand" href="#top" aria-label={`${site.company} — home`}>
        <img src="/brand/itant-logo.svg" alt="" width="38" height="38" />
        <span class="brand__name">IT&nbsp;<span>Ant</span></span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <div class="site-nav__links">
          <a href="#services">Services</a>
          <a href="#ventures">Products</a>
          <a href="#contact">Contact</a>
        </div>
        <a class="btn btn--primary" href={mailto}>{site.primaryCtaLabel}</a>
      </nav>
    </div>
  </header>

  <main id="main">
    <!-- Hero -->
    <section class="hero" id="top">
      <div class="container hero__inner">
        <div class="hero__copy">
          <span class="eyebrow">IT Ant ehf · Iceland</span>
          <h1>Your IT <span class="pun">consultAnt</span>.</h1>
          <p class="hero__sub">{site.subtagline}</p>
          <p class="hero__desc">{site.heroDescription}</p>
          <div class="hero__cta">
            <a class="btn btn--primary" href={mailto}>{site.primaryCtaLabel}</a>
            <a class="btn btn--ghost" href="#services">What we do</a>
          </div>
        </div>
        <div class="hero__art">
          <img
            src="/brand/itant-logo.svg"
            alt={`${site.company} logo — a stylised ant`}
            width="380"
            height="285"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="section" id="services">
      <div class="container">
        <div class="section__head">
          <span class="eyebrow">What we do</span>
          <h2>Dependable IT, sized for your business</h2>
          <p>
            One focused team across advisory, engineering and operations — so you
            get senior judgement without the overhead of a big agency.
          </p>
        </div>
        <div class="cards">
          {services.map((s) => (
            <article class="card">
              <span class="card__icon"><Icon name={s.icon} /></span>
              <h3>{s.title}</h3>
              <p>{s.summary}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Products / ventures -->
    <section class="section ventures" id="ventures">
      <div class="container ventures__inner">
        <div>
          <span class="eyebrow">Products &amp; ventures</span>
          <h2>{site.lineage.intro}</h2>
          <p>{site.lineage.body}</p>
          <div class="ventures__links">
            <a class="btn btn--on-ink" href={site.lineage.g9Url} rel="noopener" target="_blank">
              {site.lineage.g9Label} ↗
            </a>
            <a class="btn btn--on-ink" href={site.lineage.certainGuardUrl} rel="noopener" target="_blank">
              {site.lineage.certainGuardLabel} ↗
            </a>
          </div>
        </div>
        <div>
          <article class="venture-card">
            <h3>G9</h3>
            <p>A product house building practical software — the workshop behind our ventures.</p>
            <a href={site.lineage.g9Url} rel="noopener" target="_blank">g9.is ↗</a>
          </article>
          <article class="venture-card">
            <h3>CertainGuard</h3>
            <p>Our flagship product for dependable certificate &amp; security lifecycle management.</p>
            <a href={site.lineage.certainGuardUrl} rel="noopener" target="_blank">certainguard.g9.is ↗</a>
          </article>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="section section--mist" id="contact">
      <div class="container contact__inner">
        <div>
          <span class="eyebrow">Get in touch</span>
          <h2 class="section__head" style="margin-bottom:0.6rem">Let's talk about your IT.</h2>
          <p style="color:var(--slate);max-width:34rem">
            Have a project, a problem, or just need a second opinion? Send a note and
            we'll get back to you. No call centres, no runaround — you talk to the
            people who do the work.
          </p>
          <span class="tag">Based in {site.location}</span>
        </div>
        <div class="contact__card">
          <span class="eyebrow">Email us</span>
          <br />
          <a class="contact__email" href={mailto}>{site.email}</a>
          <p style="margin:0;color:var(--slate)">
            We reply to genuine enquiries, usually within one business day.
          </p>
          <ul class="contact__meta">
            <li><Icon name="mail" /> <a href={mailto}>{site.email}</a></li>
            <li><Icon name="pin" /> {site.location}</li>
            <li><Icon name="clock" /> Mon–Fri · Iceland (GMT)</li>
          </ul>
        </div>
      </div>
    </section>
  </main>
</Base>
