---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
---
<Base title={`Page not found — ${site.company}`} description="The page you were looking for could not be found.">
  <main id="main" class="section" style="min-height:60vh;display:grid;place-items:center;text-align:center">
    <div class="container">
      <span class="eyebrow">404</span>
      <h1 style="font-size:clamp(2rem,5vw,3rem)">This page wandered off.</h1>
      <p style="color:var(--slate);max-width:32rem;margin-inline:auto">
        The page you were looking for isn't here. Let's get you back on track.
      </p>
      <p><a class="btn btn--primary" href="/">Back to home</a></p>
    </div>
  </main>
</Base>
